              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 5 },
                { "kind": "insight_delta", "amount": 3 },
                { "kind": "flag_set", "flag": "found_treasure_cache" }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.treasure_hunt.opened",
              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 5 },
                { "kind": "qi_delta", "amount": -10 },
                { "kind": "flag_set", "flag": "found_treasure_cache" }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.action.treasure_hunt.partial_break",
              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 2 },
                { "kind": "qi_delta", "amount": -15 }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.treasure_hunt.rebound",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -12 },
                { "kind": "qi_delta", "amount": -15 }
              ]
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.action.treasure_hunt.formation_collapse",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -25 },
                { "kind": "qi_delta", "amount": -20 }
              ]
            }
          }
        },
        {
          "id": "ch_treasure_read_the_seals",
          "label": "Read the formation seals. There is a pattern — find the weak point.",
          "timeCost": "MEDIUM",
          "check": { "base": 35, "stats": { "Mind": 2, "Spirit": 1 }, "difficulty": 55, "techniqueBonusCategory": "lore_scholarship" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.treasure_hunt.cracked_clean",
              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 5 },
                { "kind": "insight_delta", "amount": 4 },
                { "kind": "attribute_delta", "stat": "Mind", "amount": 1 },
                { "kind": "flag_set", "flag": "found_treasure_cache" }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.treasure_hunt.opened",
              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 5 },
                { "kind": "flag_set", "flag": "found_treasure_cache" }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.action.treasure_hunt.partial_break",
              "stateDeltas": [
                { "kind": "item_add", "id": "spiritual_stone", "count": 2 },
                { "kind": "qi_delta", "amount": -8 }
              ]
            },
            "FAILURE": {
