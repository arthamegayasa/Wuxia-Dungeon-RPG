          "check": { "base": 30, "stats": { "Body": 2, "Agility": 1 }, "difficulty": 55, "techniqueBonusCategory": "melee_skill" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.rival_spar.dominated",
              "stateDeltas": [
                { "kind": "flag_set", "flag": "spar_winner" },
                { "kind": "attribute_delta", "stat": "Body", "amount": 2 },
                { "kind": "attribute_delta", "stat": "Charm", "amount": 1 }
