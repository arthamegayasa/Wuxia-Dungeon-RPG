    {
      "id": "AP_SOCIAL_SENIOR_BROTHER_MENTOR",
      "category": "life.social.bond",
      "version": 1,
      "weight": 35,
      "conditions": {
        "regions": ["azure_peaks"],
        "locales": ["outer_sect_courtyard", "meditation_cave"]
      },
      "timeCost": "MEDIUM",
      "text": {
        "intro": [
          "$[ap.outer.courtyard] A senior brother lingers after evening drill, watching $[CHARACTER] with quiet assessment.",
          "'Your footwork is wrong. And your breathing pattern will crack a meridian by winter.' He does not say this unkindly."
        ]
      },
      "choices": [
        {
          "id": "ch_senior_brother_accept",
          "label": "Ask him to demonstrate the correct form. Listen closely.",
          "timeCost": "MEDIUM",
          "check": { "base": 40, "stats": { "Mind": 1, "Spirit": 1 }, "difficulty": 45, "techniqueBonusCategory": "lore_scholarship" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.senior_mentor.deep_bond",
              "stateDeltas": [
                { "kind": "flag_set", "flag": "befriend_sect_disciple" },
                { "kind": "flag_set", "flag": "senior_brother_mentor" },
                { "kind": "attribute_delta", "stat": "Mind", "amount": 1 },
                { "kind": "meditation_progress", "base": 10, "insightBonus": 2 }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.senior_mentor.corrected",
              "stateDeltas": [
                { "kind": "flag_set", "flag": "befriend_sect_disciple" },
                { "kind": "flag_set", "flag": "senior_brother_mentor" },
                { "kind": "meditation_progress", "base": 6 }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.action.senior_mentor.partial",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 1 }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.senior_mentor.missed",
              "stateDeltas": []
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.action.senior_mentor.embarrassed",
              "stateDeltas": [
                { "kind": "attribute_delta", "stat": "Charm", "amount": -1 }
              ]
            }
          }
        },
        {
          "id": "ch_senior_brother_deflect",
          "label": "Thank him politely. Continue practicing alone.",
          "timeCost": "SHORT",
          "outcomes": {
            "SUCCESS": {
              "narrativeKey": "ap.action.senior_mentor.declined",
              "stateDeltas": []
            },
            "FAILURE": {
              "narrativeKey": "ap.action.senior_mentor.declined",
              "stateDeltas": []
            }
          }
        }
      ],
      "repeat": "unlimited"
    },
