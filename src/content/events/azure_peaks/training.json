{
  "version": 1,
  "events": [
    {
      "id": "AP_TRAINING_ELDER_CULTIVATION_GUIDANCE",
      "category": "life.training",
      "version": 1,
      "weight": 25,
      "conditions": { "regions": ["azure_peaks"] },
      "timeCost": "LONG",
      "text": {
        "intro": [
          "$[ap.elder.quarters] The elder's eyes are closed. $[CHARACTER] waits at the threshold until a single finger lifts.",
          "'Sit. Show me your qi. Don't hide it — I can smell a blocked meridian from across the room.'"
        ]
      },
      "choices": [
        {
          "id": "ch_guidance_focused",
          "label": "Sit in stillness and follow the elder's directions.",
          "timeCost": "LONG",
          "check": { "base": 35, "stats": { "Spirit": 2, "Mind": 1 }, "difficulty": 55, "techniqueBonusCategory": "cultivation_attempt" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.guidance.breakthrough",
              "stateDeltas": [
                { "kind": "meridian_open", "id": 5 },
                { "kind": "meditation_progress", "base": 20, "insightBonus": 3 },
                { "kind": "insight_delta", "amount": 4 }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.guidance.steady",
              "stateDeltas": [
                { "kind": "meridian_open", "id": 5 },
                { "kind": "meditation_progress", "base": 10 }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.action.guidance.partial",
              "stateDeltas": [
                { "kind": "meditation_progress", "base": 5 },
                { "kind": "insight_delta", "amount": 1 }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.guidance.missed",
              "stateDeltas": []
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.action.guidance.backlash",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -8 },
                { "kind": "qi_delta", "amount": -5 }
              ]
            }
          }
        },
        {
          "id": "ch_guidance_passive",
          "label": "Listen but do not push. Watch the elder's technique.",
          "timeCost": "MEDIUM",
          "outcomes": {
            "SUCCESS": {
              "narrativeKey": "ap.action.guidance.observe",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 2 },
                { "kind": "flag_set", "flag": "observed_elder_technique" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.guidance.observe",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 1 }
              ]
            }
          }
        }
      ],
      "repeat": "unlimited"
    },
    {
      "id": "AP_TRAINING_PILL_ASSISTED_BREAKTHROUGH",
