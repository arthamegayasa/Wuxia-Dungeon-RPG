                { "kind": "item_remove", "id": "manual_iron_mountain_body_seal", "count": 1 },
                { "kind": "technique_learn", "id": "iron_mountain_body_seal" },
                { "kind": "flag_set", "flag": "learned_iron_mountain_body_seal" }
