      "version": 1,
      "weight": 70,
      "conditions": { "regions": ["azure_peaks"] },
      "timeCost": "MEDIUM",
      "text": {
        "intro": [
          "$[ap.alchemy.pavilion] An elder waves $[CHARACTER] over.",
          "'Boy. Girl. Whichever. Take this jar to the Crystal Vale steward, and don't drop it.'"
