          "timeCost": "SHORT",
          "outcomes": {
            "SUCCESS": { "narrativeKey": "ap.action.chore.skimped" },
            "FAILURE": { "narrativeKey": "ap.action.chore.skimped" }
          }
        }
      ],
      "repeat": "unlimited"
    },
