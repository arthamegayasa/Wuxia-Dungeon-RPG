        "intro": [
          "On the road between the mountain and the plains, $[CHARACTER] encounters another traveller — a fellow wanderer moving in the opposite direction.",
          "Neither the peaks nor the fields own this stretch of road. It belongs to those in passage."
        ],
        "body": [
          "Cross-region travellers sometimes share valuable information. Other times they are bandits testing their luck."
        ]
      },
      "choices": [
        {
          "id": "ch_encounter_talk",
