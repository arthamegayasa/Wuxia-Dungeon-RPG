{
  "version": 1,
  "events": [
    {
      "id": "AP_TRANSITION_DESCEND_TO_PLAINS",
      "category": "life.transition",
      "version": 1,
      "weight": 80,
      "conditions": {
        "regions": ["azure_peaks"]
      },
      "timeCost": "LONG",
      "text": {
        "intro": [
          "The mountain trails grow steep as $[CHARACTER] descends toward the Yellow Plains. The dense qi of Azure Peaks thins with every step downward.",
          "Below, the patchwork of villages and fields spreads out like a faded tapestry — the mortal world, waiting."
        ],
        "body": [
          "There are reasons to return below: supplies, family, unfinished matters. A cultivator who cannot walk among mortals is only half a person."
        ]
      },
      "choices": [
        {
          "id": "ch_descend_return",
          "label": "Descend to the Yellow Plains.",
          "timeCost": "LONG",
          "check": { "base": 60, "stats": { "Body": 1, "Agility": 1 }, "difficulty": 40 },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.transition.descend.crit_success",
              "stateDeltas": [
                { "kind": "region_change", "regionId": "yellow_plains" },
                { "kind": "insight_delta", "amount": 3 },
                { "kind": "karma_delta", "amount": 1 }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.transition.descend.success",
              "stateDeltas": [
                { "kind": "region_change", "regionId": "yellow_plains" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.transition.descend.failure",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -8 },
                { "kind": "region_change", "regionId": "yellow_plains" }
              ]
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.transition.descend.crit_failure",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -20 },
                { "kind": "region_change", "regionId": "yellow_plains" }
              ]
            }
          }
        },
        {
          "id": "ch_descend_stay",
          "label": "Reconsider — the mountain path is not yet finished with you.",
          "timeCost": "SHORT",
          "check": { "base": 70, "stats": { "Mind": 1 }, "difficulty": 30 },
          "outcomes": {
            "SUCCESS": {
              "narrativeKey": "ap.transition.descend.stay",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 2 }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.transition.descend.stay_fail",
              "stateDeltas": []
            }
          }
        }
      ],
      "repeat": "unlimited"
    },
    {
