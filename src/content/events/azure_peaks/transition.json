    {
      "id": "AP_TRANSITION_WANDERING_MASTER_VISIT",
      "category": "life.transition",
      "version": 1,
      "weight": 25,
      "conditions": {
        "regions": ["yellow_plains", "azure_peaks"],
        "minStat": { "Mind": 10, "Spirit": 8 }
      },
      "timeCost": "MEDIUM",
      "text": {
        "intro": [
          "An old figure sits at the roadside, robes dusty from travel. They seem unremarkable — yet the air around them does not move correctly.",
          "$[CHARACTER] slows. Wandering masters are not always what they appear, but ignoring one entirely is also a kind of foolishness."
        ],
        "body": [
          "The old one's eyes carry the weight of many cultivated years. When they finally speak, every word lands with deliberate precision.",
          "\"You seek the high road or the low road, young one? It does not matter as much as you think.\""
        ]
      },
      "choices": [
        {
          "id": "ch_wmaster_sit",
          "label": "Sit and listen for as long as the master will speak.",
          "timeCost": "MEDIUM",
          "check": { "base": 50, "stats": { "Mind": 3, "Spirit": 2 }, "difficulty": 60, "techniqueBonusCategory": "meditation" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.transition.wmaster.crit_success",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 10 },
                { "kind": "flag_set", "flag": "seen_technique_wandering_path" },
                { "kind": "karma_delta", "amount": 3 },
                { "kind": "region_change", "regionId": "azure_peaks" }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.transition.wmaster.success",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 5 },
                { "kind": "flag_set", "flag": "seen_technique_wandering_path" },
                { "kind": "region_change", "regionId": "azure_peaks" }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.transition.wmaster.partial",
              "stateDeltas": [
                { "kind": "insight_delta", "amount": 2 },
                { "kind": "region_change", "regionId": "azure_peaks" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.transition.wmaster.failure",
              "stateDeltas": [
                { "kind": "region_change", "regionId": "yellow_plains" }
              ]
            }
