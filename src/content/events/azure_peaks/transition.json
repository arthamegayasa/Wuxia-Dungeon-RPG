          "id": "ch_wmaster_ask",
          "label": "Ask a direct question about the path ahead.",
          "timeCost": "SHORT",
          "check": { "base": 60, "stats": { "Mind": 2, "Charm": 1 }, "difficulty": 50 },
          "outcomes": {
