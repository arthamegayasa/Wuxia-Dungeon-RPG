    {
      "id": "AP_GATE_QS_AWAKENING",
      "category": "life.realm_gate",
      "version": 1,
      "weight": 200,
      "conditions": {
        "regions": ["azure_peaks"],
        "customPredicate": "bt9_cultivation_full"
      },
      "timeCost": "EPOCH",
      "text": {
        "intro": [
          "$[ap.gate.qs.sky] The summit catches the last light. $[CHARACTER] has been still since dawn, qi cycling through all nine tempered layers in a single breath.",
          "The barrier between mortal refinement and true qi sensing shimmers — thin as morning ice, vast as the valley below."
        ],
        "body": [
          "The body has been hardened to its limit. Now comes the true test: whether the spirit can break through to feel the world's own qi."
        ]
      },
      "choices": [
        {
          "id": "ch_qs_awakening_attempt",
          "label": "Attempt the Qi Sensing awakening.",
          "timeCost": "EPOCH",
          "check": { "base": 50, "stats": { "Mind": 2, "Spirit": 3 }, "difficulty": 60, "techniqueBonusCategory": "cultivation_attempt" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.gate.qs.awakening.crit",
              "stateDeltas": [
                { "kind": "attempt_realm_crossing", "transition": "bt9_to_qs" },
                { "kind": "insight_delta", "amount": 8 },
                { "kind": "flag_set", "flag": "qi_sensing_awakened" }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.gate.qs.awakening.success",
              "stateDeltas": [
                { "kind": "attempt_realm_crossing", "transition": "bt9_to_qs" },
                { "kind": "flag_set", "flag": "qi_sensing_awakened" }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.gate.qs.awakening.partial",
              "stateDeltas": [
                { "kind": "attempt_realm_crossing", "transition": "bt9_to_qs" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.gate.qs.awakening.fail",
              "stateDeltas": [
                { "kind": "cultivation_progress_delta", "amount": -50 },
                { "kind": "hp_delta", "amount": -10 }
              ]
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.gate.qs.awakening.crit_fail",
              "stateDeltas": [
                { "kind": "cultivation_progress_delta", "amount": -75 },
                { "kind": "hp_delta", "amount": -20 },
                { "kind": "qi_delta", "amount": -15 }
              ]
            }
          }
        },
        {
          "id": "ch_qs_awakening_defer",
          "label": "Withdraw — the moment is not yet right.",
          "timeCost": "SHORT",
          "check": { "base": 100, "difficulty": 0 },
          "outcomes": {
            "SUCCESS": {
