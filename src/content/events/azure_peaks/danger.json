{
  "version": 1,
  "events": [
    {
      "id": "AP_DANGER_RIVAL_SECT_INCURSION",
      "category": "life.danger.combat",
      "version": 1,
      "weight": 20,
      "conditions": {
        "regions": ["azure_peaks"]
      },
      "timeCost": "INSTANT",
      "text": {
        "intro": [
          "$[ap.mountain.path] A column of unfamiliar disciples sweeps over the ridge — dark-crested robes, hands already forming seals.",
          "Their leader points at $[CHARACTER]. 'Azure Peaks scum. This pass belongs to us now. Surrender your sect token.'"
        ]
      },
      "choices": [
        {
          "id": "ch_rival_sect_fight",
          "label": "Draw qi. Hold the pass. Make them regret the crossing.",
          "timeCost": "INSTANT",
          "check": { "base": 25, "stats": { "Body": 2, "Spirit": 1 }, "difficulty": 70, "techniqueBonusCategory": "melee_skill" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.rival_incursion.routed",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -5 },
                { "kind": "attribute_delta", "stat": "Body", "amount": 1 },
                { "kind": "insight_delta", "amount": 3 },
                { "kind": "flag_set", "flag": "repelled_rival_sect" }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.rival_incursion.held",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -15 },
                { "kind": "flag_set", "flag": "repelled_rival_sect" }
              ]
            },
            "PARTIAL": {
              "narrativeKey": "ap.action.rival_incursion.forced_back",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -25 },
                { "kind": "qi_delta", "amount": -10 }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.rival_incursion.overwhelmed",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -35 },
                { "kind": "qi_delta", "amount": -15 }
              ]
            },
            "CRIT_FAILURE": {
              "narrativeKey": "ap.action.rival_incursion.overwhelmed",
              "deathCause": "combat_melee"
            }
          }
        },
        {
          "id": "ch_rival_sect_call_for_help",
          "label": "Fall back toward the sect gate. Shout for the patrol.",
          "timeCost": "INSTANT",
          "check": { "base": 35, "stats": { "Agility": 1, "Mind": 1 }, "difficulty": 50, "techniqueBonusCategory": "dodge_flee" },
          "outcomes": {
            "SUCCESS": {
              "narrativeKey": "ap.action.rival_incursion.reinforced",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -5 },
                { "kind": "flag_set", "flag": "called_sect_patrol" },
                { "kind": "flag_set", "flag": "rival_sect_repelled" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.rival_incursion.forced_back",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -18 },
                { "kind": "qi_delta", "amount": -8 }
              ]
            }
          }
        },
        {
          "id": "ch_rival_sect_storm_step_flee",
          "label": "Invoke the howling storm step — dissolve into the wind before they can lock you.",
          "timeCost": "INSTANT",
          "unlockedBy": "flee_mounted_pursuer",
          "check": { "base": 55, "stats": { "Agility": 2 }, "difficulty": 40, "techniqueBonusCategory": "dodge_flee" },
          "outcomes": {
            "CRIT_SUCCESS": {
              "narrativeKey": "ap.action.rival_incursion.vanished",
              "stateDeltas": [
                { "kind": "flag_set", "flag": "escaped_rival_sect_unseen" },
                { "kind": "insight_delta", "amount": 2 }
              ]
            },
            "SUCCESS": {
              "narrativeKey": "ap.action.rival_incursion.vanished",
              "stateDeltas": [
                { "kind": "flag_set", "flag": "escaped_rival_sect_unseen" }
              ]
            },
            "FAILURE": {
              "narrativeKey": "ap.action.rival_incursion.forced_back",
              "stateDeltas": [
                { "kind": "hp_delta", "amount": -10 }
              ]
            }
          }
        }
      ],
      "repeat": "unlimited"
    },
    {
